{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProductivityOS",
  "version": "0.2.0",
  "identifier": "com.rahulborana.productivityos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ProductivityOS",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true,
        "center": true,
        "theme": "Dark"
      },
      {
        "label": "floating-timer",
        "url": "index.html#/float",
        "title": "Timer",
        "width": 268,
        "height": 108,
        "minWidth": 120,
        "minHeight": 48,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:productivityos.db"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Rahul Borana",
    "copyright": "© 2026 Rahul Borana. All Rights Reserved.",
    "shortDescription": "Personal productivity desktop app",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" },
      "nsis": {
        "installMode": "currentUser",
        "compression": "lzma"
      }
    }
  }
}
